{
  "manifest_version": 3,
  "name": "GitLab MR Private Reviewer",
  "version": "1.0.0",
  "description": "自動抓取自架 GitLab MR 的代碼差異並整合 Generative AI 進行 Code Review",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitLab MR Reviewer 設定",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
